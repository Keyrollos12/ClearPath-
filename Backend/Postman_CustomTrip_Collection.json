{
  "info": {
    "_postman_id": "clearpath-customtrip-module",
    "name": "ClearPath - CustomTrip + Booking Module",
    "description": "Complete Postman Collection to test CustomTrip and Booking endpoints. Base URL: http://localhost:3000\n\nPrerequisites:\n1. Register/Login as a user\n2. Create an Experience (as admin)\n3. Create Activities (as admin)\n4. Use the obtained tokens and IDs in the collection variables",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. Auth - Register User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\",\n  \"phoneNumber\": \"+201234567890\",\n  \"gender\": \"male\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["auth", "register"]
        }
      },
      "response": []
    },
    {
      "name": "0. Auth - Login User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "1. Create Custom Trip (from Experience)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"experienceId\": \"{{experienceId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/customTrip",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["customTrip"]
        }
      },
      "response": []
    },
    {
      "name": "2. Get All User Trips",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/customTrip",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["customTrip"]
        }
      },
      "response": []
    },
    {
      "name": "3. Get One Trip",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/customTrip/{{customTripId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["customTrip", "{{customTripId}}"]
        }
      },
      "response": []
    },
    {
      "name": "4. Smart View - Get Final Trip (Experience OR CustomTrip)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/customTrip/view/{{experienceId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["customTrip", "view", "{{experienceId}}"]
        }
      },
      "response": []
    },
    {
      "name": "4.5 Preview Builder - Show ALL Changes",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/customTrip/preview/{{customTripId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["customTrip", "preview", "{{customTripId}}"]
        }
      },
      "response": []
    },
    {
      "name": "5. Add Activity to Day",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"day_number\": 1,\n  \"activity\": \"{{activityId}}\",\n  \"provider\": \"{{providerId}}\",\n  \"price\": 150\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/customTrip/{{customTripId}}/add-activity",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["customTrip", "{{customTripId}}", "add-activity"]
        }
      },
      "response": []
    },
    {
      "name": "6. Remove Activity from Day",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"day_number\": 1,\n  \"activityId\": \"{{activityId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/customTrip/{{customTripId}}/remove-activity",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["customTrip", "{{customTripId}}", "remove-activity"]
        }
      },
      "response": []
    },
    {
      "name": "7. Add Day",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"day_number\": 3,\n  \"activities\": [\n    {\n      \"activity\": \"{{activityId}}\",\n      \"provider\": \"{{providerId}}\",\n      \"price\": 200\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/customTrip/{{customTripId}}/add-day",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["customTrip", "{{customTripId}}", "add-day"]
        }
      },
      "response": []
    },
    {
      "name": "8. Remove Day",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"day_number\": 2\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/customTrip/{{customTripId}}/remove-day",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["customTrip", "{{customTripId}}", "remove-day"]
        }
      },
      "response": []
    },
    {
      "name": "9. Add Extra Activity",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"activity\": \"{{activityId}}\",\n  \"provider\": \"{{providerId}}\",\n  \"price\": 100,\n  \"day\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/customTrip/{{customTripId}}/add-extra",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["customTrip", "{{customTripId}}", "add-extra"]
        }
      },
      "response": []
    },
    {
      "name": "10. Remove Extra Activity",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"activityId\": \"{{activityId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/customTrip/{{customTripId}}/remove-extra",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["customTrip", "{{customTripId}}", "remove-extra"]
        }
      },
      "response": []
    },
    {
      "name": "11. Restore Day",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"day_number\": 2\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/customTrip/{{customTripId}}/restore-day",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["customTrip", "{{customTripId}}", "restore-day"]
        }
      },
      "response": []
    },
    {
      "name": "12. Restore Activity",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"day_number\": 1,\n  \"activityId\": \"{{activityId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/customTrip/{{customTripId}}/restore-activity",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["customTrip", "{{customTripId}}", "restore-activity"]
        }
      },
      "response": []
    },
    {
      "name": "13. Restore Extra Activity",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"activityId\": \"{{activityId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/customTrip/{{customTripId}}/restore-extra",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["customTrip", "{{customTripId}}", "restore-extra"]
        }
      },
      "response": []
    },
    {
      "name": "14. Delete Custom Trip",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/customTrip/{{customTripId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["customTrip", "{{customTripId}}"]
        }
      },
      "response": []
    },
    {
      "name": "15. Book Experience Directly",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"experienceId\": \"{{experienceId}}\",\n  \"travel_date\": \"2025-06-15\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/booking",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["booking"]
        }
      },
      "response": []
    },
    {
      "name": "16. Book Custom Trip",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customTripId\": \"{{customTripId}}\",\n  \"travel_date\": \"2025-06-15\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/booking",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["booking"]
        }
      },
      "response": []
    },
    {
      "name": "17. Get My Bookings",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/booking",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["booking"]
        }
      },
      "response": []
    },
    {
      "name": "18. Get One Booking",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/booking/{{bookingId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["booking", "{{bookingId}}"]
        }
      },
      "response": []
    },
    {
      "name": "19. Cancel Booking",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/booking/{{bookingId}}/cancel",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["booking", "{{bookingId}}", "cancel"]
        }
      },
      "response": []
    },
    {
      "name": "20. Delete Booking",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/booking/{{bookingId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["booking", "{{bookingId}}"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "userToken",
      "value": "YOUR_USER_JWT_TOKEN_HERE"
    },
    {
      "key": "customTripId",
      "value": "CUSTOM_TRIP_ID_HERE"
    },
    {
      "key": "experienceId",
      "value": "EXPERIENCE_ID_HERE"
    },
    {
      "key": "activityId",
      "value": "ACTIVITY_ID_HERE"
    },
    {
      "key": "providerId",
      "value": "PROVIDER_ID_HERE"
    },
    {
      "key": "bookingId",
      "value": "BOOKING_ID_HERE"
    }
  ]
}
