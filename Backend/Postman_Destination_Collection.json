{
  "info": {
    "_postman_id": "clearpath-destination-module",
    "name": "ClearPath - Destination Module",
    "description": "Postman Collection to test Destination endpoints. Base URL: http://localhost:3000/destination",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Get All Destinations (Public)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/destination",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["destination"]
        }
      },
      "response": []
    },
    {
      "name": "2. Get One Destination (Public)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/destination/{{destinationId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["destination", "{{destinationId}}"]
        }
      },
      "response": []
    },
    {
      "name": "3. Create Destination (Admin Only)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Pyramids of Giza\",\n  \"location\": \"Giza, Egypt\",\n  \"city\": \"Giza\",\n  \"description\": \"The Great Pyramid of Giza is the oldest and largest of the pyramids in the Giza pyramid complex.\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/destination",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["destination"]
        }
      },
      "response": []
    },
    {
      "name": "4. Update Destination (Admin Only)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Updated Pyramids\",\n  \"description\": \"Updated description for the Pyramids of Giza.\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/destination/{{destinationId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["destination", "{{destinationId}}"]
        }
      },
      "response": []
    },
    {
      "name": "5. Delete Destination (Admin Only)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "http://localhost:3000/destination/{{destinationId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["destination", "{{destinationId}}"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "destinationId",
      "value": "64f8a1b2c3d4e5f6a7b8c9d0"
    },
    {
      "key": "adminToken",
      "value": "YOUR_ADMIN_JWT_TOKEN_HERE"
    }
  ]
}

